# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Gmail OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://hirecanvas.in/api/auth/callback

# Gmail sync (optional — how many messages to list per job; uses Gmail search query syntax)
# GMAIL_SYNC_QUERY=subject:(job OR interview OR application)
# GMAIL_SYNC_PAGE_SIZE=100
# GMAIL_SYNC_MAX_MESSAGES=500

# AI
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
PYTHON_NLP_SERVICE_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
STRIPE_ELITE_PRICE_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Admin revenue snapshot (optional; used in /api/admin/overview net margin)
MONTHLY_INFRA_ESTIMATE_CENTS=5000

# AWS SES
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@hirecanvas.in

# Security
TOKEN_ENCRYPTION_KEY=
SYNC_CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=https://hirecanvas.in
NODE_ENV=production
