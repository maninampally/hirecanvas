{
  "name": "hirecanvas",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "tsx --test src/lib/ai/*.test.ts",
    "sync:schedule:daily": "tsx --env-file=.env.local src/lib/sync/runDailySyncScheduler.ts",
    "diagnose": "tsx --env-file=.env.local scripts/diagnose.ts",
    "reset:rejected": "tsx --env-file=.env.local scripts/resetRejected.ts",
    "check:keys": "tsx --env-file=.env.local scripts/checkKeys.ts",
    "worker:sync": "tsx --env-file=.env.local src/lib/queue/workers/runSyncWorker.ts",
    "worker:extract": "tsx --env-file=.env.local src/lib/queue/workers/runExtractionWorker.ts",
    "worker:nudge": "tsx --env-file=.env.local src/lib/queue/workers/runNudgeWorker.ts",
    "worker:digest": "tsx --env-file=.env.local src/lib/queue/workers/runDigestWorker.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-sesv2": "^3.1032.0",
    "@hookform/resolvers": "^5.2.2",
    "@sentry/nextjs": "^10.49.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.99.0",
    "bullmq": "^5.74.1",
    "cmdk": "^1.1.1",
    "fastest-levenshtein": "^1.0.16",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.3.5",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "stripe": "^22.0.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
